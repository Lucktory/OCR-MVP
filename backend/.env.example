# Default: Groq — free tier, no card required.
# Sign up at https://console.groq.com and create an API key.
PROVIDER=groq
GROQ_API_KEY=gsk_your_key_here

# Optional: override the model. Check current Groq vision models at
# https://console.groq.com/docs/models — must support vision/image input.
# MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# To use OpenAI instead:
# PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# MODEL=gpt-4o

CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3006,http://localhost:3007
